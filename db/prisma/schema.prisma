generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issue {
  id            String   @id @default(uuid())
  title         String
  summary       String
  issueType     String
  severity      String
  status        String
  priority      String   @default("Normal")
  operatorPosture String @default("Monitoring")
  ownerName     String?
  audience      String?
  openGapsCount Int      @default(0)
  sourcesCount  Int      @default(0)
  lastActivityAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  briefVersions BriefVersion[]
  briefComparisons BriefComparison[]
  artifactExports ArtifactExport[]
  circulationEvents CirculationEvent[]
  activities    IssueActivity[]
  sources       Source[]
  gaps          Gap[]
  internalInputs InternalInput[]

  @@index([updatedAt])
  @@index([lastActivityAt])
}

model BriefVersion {
  id                        String   @id @default(uuid())
  issueId                    String
  mode                       String
  versionNumber              Int
  generatedFromIssueUpdatedAt DateTime
  circulationState           String   @default("Ready for review")
  circulationNotes           String?
  derivedFromBriefVersionId  String?
  artifact                   Json
  createdAt                  DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  derivedFromBriefVersion BriefVersion? @relation("BriefVersionDerivation", fields: [derivedFromBriefVersionId], references: [id], onDelete: SetNull)
  derivedVersions        BriefVersion[] @relation("BriefVersionDerivation")
  comparisonsFrom        BriefComparison[] @relation("BriefComparisonFrom")
  comparisonsTo          BriefComparison[] @relation("BriefComparisonTo")
  artifactExports        ArtifactExport[]
  circulationEvents      CirculationEvent[]

  @@index([issueId, mode, createdAt])
  @@unique([issueId, mode, versionNumber])
  @@index([derivedFromBriefVersionId])
}

model BriefComparison {
  id               String   @id @default(uuid())
  issueId           String
  mode              String
  fromBriefVersionId String
  toBriefVersionId   String
  changeCount       Int
  summary           Json
  createdAt         DateTime @default(now())

  issue          Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  fromBriefVersion BriefVersion @relation("BriefComparisonFrom", fields: [fromBriefVersionId], references: [id], onDelete: Cascade)
  toBriefVersion   BriefVersion @relation("BriefComparisonTo", fields: [toBriefVersionId], references: [id], onDelete: Cascade)

  @@unique([fromBriefVersionId, toBriefVersionId])
  @@index([issueId, mode, createdAt])
}

model ArtifactExport {
  id            String   @id @default(uuid())
  issueId        String
  briefVersionId String
  mode           String
  format         String
  filename       String
  mimeType       String
  content        String
  createdAt      DateTime @default(now())

  issue        Issue       @relation(fields: [issueId], references: [id], onDelete: Cascade)
  briefVersion BriefVersion @relation(fields: [briefVersionId], references: [id], onDelete: Cascade)
  circulationEvents CirculationEvent[]

  @@index([issueId, createdAt])
  @@index([briefVersionId, createdAt])
}

model CirculationEvent {
  id            String   @id @default(uuid())
  issueId        String
  briefVersionId String
  exportId       String?
  actorLabel     String?
  eventType      String
  channel        String?
  audienceLabel  String?
  postureState   String
  note           String?
  createdAt      DateTime @default(now())

  issue        Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  briefVersion BriefVersion @relation(fields: [briefVersionId], references: [id], onDelete: Cascade)
  export       ArtifactExport? @relation(fields: [exportId], references: [id], onDelete: SetNull)

  @@index([issueId, createdAt])
  @@index([briefVersionId, createdAt])
  @@index([exportId])
}

model IssueActivity {
  id        String   @id @default(uuid())
  issueId   String
  kind      String
  summary   String
  refType   String?
  refId     String?
  actorLabel String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
  @@index([issueId, kind, createdAt])
}

model Source {
  id             String   @id @default(uuid())
  issueId         String
  sourceCode      String
  tier           String
  title          String
  note           String?
  snippet        String?
  reliability    String?
  linkedSection  String?
  url            String?
  timestampLabel String?
  createdAt      DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, tier, createdAt])
  @@unique([issueId, sourceCode])
}

model Gap {
  id                          String   @id @default(uuid())
  issueId                     String
  title                       String
  whyItMatters                String
  stakeholder                 String
  linkedSection               String
  severity                    String
  status                      String
  prompt                      String
  resolvedByInternalInputId   String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  resolvedByInternalInput InternalInput? @relation("GapResolvedByInternalInput", fields: [resolvedByInternalInputId], references: [id], onDelete: Restrict)

  @@index([issueId, status, createdAt])
  @@index([resolvedByInternalInputId])
}

model InternalInput {
  id             String   @id @default(uuid())
  issueId        String
  role           String
  name           String
  response       String
  confidence     String
  linkedSection  String?
  visibility     String?
  timestampLabel String?
  createdAt      DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  resolvedGaps Gap[] @relation("GapResolvedByInternalInput")

  @@index([issueId, createdAt])
}

