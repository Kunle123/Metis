generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issue {
  id            String   @id @default(uuid())
  title         String
  summary       String
  issueType     String
  severity      String
  status        String
  ownerName     String?
  audience      String?
  openGapsCount Int      @default(0)
  sourcesCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  briefVersions BriefVersion[]

  @@index([updatedAt])
}

model BriefVersion {
  id                        String   @id @default(uuid())
  issueId                    String
  mode                       String
  versionNumber              Int
  generatedFromIssueUpdatedAt DateTime
  artifact                   Json
  createdAt                  DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, mode, createdAt])
  @@unique([issueId, mode, versionNumber])
}

