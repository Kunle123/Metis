generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issue {
  id            String   @id @default(uuid())
  title         String
  summary       String
  issueType     String
  severity      String
  status        String
  ownerName     String?
  audience      String?
  openGapsCount Int      @default(0)
  sourcesCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  briefVersions BriefVersion[]
  sources       Source[]
  gaps          Gap[]
  internalInputs InternalInput[]

  @@index([updatedAt])
}

model BriefVersion {
  id                        String   @id @default(uuid())
  issueId                    String
  mode                       String
  versionNumber              Int
  generatedFromIssueUpdatedAt DateTime
  artifact                   Json
  createdAt                  DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, mode, createdAt])
  @@unique([issueId, mode, versionNumber])
}

model Source {
  id             String   @id @default(uuid())
  issueId         String
  sourceCode      String
  tier           String
  title          String
  note           String?
  snippet        String?
  reliability    String?
  linkedSection  String?
  url            String?
  timestampLabel String?
  createdAt      DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, tier, createdAt])
  @@unique([issueId, sourceCode])
}

model Gap {
  id                          String   @id @default(uuid())
  issueId                     String
  title                       String
  whyItMatters                String
  stakeholder                 String
  linkedSection               String
  severity                    String
  status                      String
  prompt                      String
  resolvedByInternalInputId   String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  resolvedByInternalInput InternalInput? @relation("GapResolvedByInternalInput", fields: [resolvedByInternalInputId], references: [id], onDelete: Restrict)

  @@index([issueId, status, createdAt])
  @@index([resolvedByInternalInputId])
}

model InternalInput {
  id             String   @id @default(uuid())
  issueId        String
  role           String
  name           String
  response       String
  confidence     String
  linkedSection  String?
  visibility     String?
  timestampLabel String?
  createdAt      DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  resolvedGaps Gap[] @relation("GapResolvedByInternalInput")

  @@index([issueId, createdAt])
}

