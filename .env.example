DATABASE_URL=
# Optional: required for "Structure with AI" on New issue. If unset, the API returns 503.
# OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=
MESSAGES_AI_CLEANUP_ENABLED=false  # Optional; off by default — set true (with OPENAI_API_KEY) to enable Messages wording polish only.
BRIEF_AI_SYNTHESIS_ENABLED=false  # Optional; off by default — set true (with OPENAI_API_KEY) for AI-assisted executive-summary text on full-issue brief regeneration (deterministic artifact is always generated).

# Issue workspace capture-notes AI extraction suggestions (endpoint only — no writes). Default off.
NOTES_CAPTURE_AI_ENABLED=false
